{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "timestamp_utc", "source", "sequence_id", "objects"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "timestamp_utc": {"type": "string"},
    "source": {"type": "string"},
    "sequence_id": {"type": "integer"},
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "class", "confidence", "bbox", "range_m", "rel_velocity_mps", "source_flags"],
        "properties": {
          "id": {"type": "string"},
          "class": {"type": "string"},
          "confidence": {"type": "number"},
          "bbox": {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4},
          "range_m": {"type": "number"},
          "rel_velocity_mps": {"type": "number"},
          "source_flags": {"type": "array", "items": {"type": "string"}},
          "track_state": {"type": "string", "enum": ["new", "tracked", "lost"]},
          "uncertainty": {
            "type": "object",
            "properties": {
              "range_cov": {"type": "number"},
              "velocity_cov": {"type": "number"},
              "angle_cov": {"type": "number"}
            }
          }
        }
      }
    }
  }
}
