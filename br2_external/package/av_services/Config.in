config BR2_PACKAGE_AV_SERVICES
	bool "av_services"
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBCURL_FORCE_TLS
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_LIBCURL_OPENSSL
	select BR2_PACKAGE_PYTHON_PAHO_MQTT
	select BR2_PACKAGE_PYTHON_PSUTIL
	help
	  Cross-build and install av_services runtime binaries,
	  default config files, and service startup units.
	  Installs systemd .service units when BR2_INIT_SYSTEMD=y,
	  or a BusyBox SysV init script otherwise.
